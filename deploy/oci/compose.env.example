# Used by docker compose -f docker-compose.prod.yml when building the frontend image.
# Copy to the repo root as `.env` on the VM (Compose auto-loads it).
#
# Prefer a same-origin relative API path (works with host Nginx /api/ proxy
# and does not embed a changing public IP into the JS bundle):
VITE_BASE_URL=/api/v1
#
# Absolute form also works if you need it:
# VITE_BASE_URL=https://129-146-1-2.sslip.io/api/v1
