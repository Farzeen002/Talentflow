# Copy to backend/.env on the VM and fill in real secrets.
# Replace EVERY occurrence of HOST_PLACEHOLDER with your sslip.io name, e.g. 129-146-1-2.sslip.io
#
# Derive hostname from public IP:
#   129.146.1.2  →  129-146-1-2.sslip.io

APP_ENV=staging
FRONTEND_URL=https://HOST_PLACEHOLDER
APP_PUBLIC_HOST=HOST_PLACEHOLDER
APP_PUBLIC_URL=https://HOST_PLACEHOLDER

# Comma-separated browser origins (no *)
CORS_ORIGINS=https://HOST_PLACEHOLDER

MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=recrutment_auto
REDIS_URL=redis://redis:6379/0

# Generate strong values for staging/demo:
#   openssl rand -hex 32
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
FERNET_KEY=CHANGE_ME_FERNET_KEY
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# Local volume storage is OK for Always Free demo (APP_ENV=staging).
# Switch to gcs + full GCP_* when you set APP_ENV=production.
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=/data/storage

# Google OAuth — update redirect URI in Google Cloud Console to match:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://HOST_PLACEHOLDER/api/v1/auth/callback

# Microsoft OAuth — update redirect URI in Azure App Registration to match:
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://HOST_PLACEHOLDER/api/v1/auth/microsoft/callback
OUTLOOK_NVITE_FOLDER=Nvite

# OpenAI / LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional GCS (required only when APP_ENV=production)
# STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=
# GCP_PROJECT_ID=
# GCP_PRIVATE_KEY_ID=
# GCP_PRIVATE_KEY=
# GCP_CLIENT_EMAIL=
# GCP_CLIENT_ID=

REPORT_TZ=Asia/Kolkata
