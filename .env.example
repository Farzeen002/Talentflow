# TalentFlow Free Hosting Environment Template
# Copy values into:
# - Render backend/worker environment variables
# - Netlify frontend environment variables

############################
# Backend (Render)
############################
APP_ENV=production
PORT=10000

FRONTEND_URL=https://your-netlify-site.netlify.app
APP_PUBLIC_URL=https://your-render-service.onrender.com
CORS_ORIGINS=https://your-netlify-site.netlify.app

MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=recrutment_auto
REDIS_URL=rediss://default:<password>@<host>:<port>

JWT_SECRET_KEY=replace_with_32_plus_char_secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
FERNET_KEY=replace_with_fernet_key
INTERNAL_API_TOKEN=replace_with_internal_api_token

STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=your_gcs_bucket_name
GCP_PROJECT_ID=your_gcp_project_id
GCP_PRIVATE_KEY_ID=your_gcp_private_key_id
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCP_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GCP_CLIENT_ID=your_gcp_client_id

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-render-service.onrender.com/api/v1/auth/callback

MICROSOFT_TENANT_ID=your_microsoft_tenant_id
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=https://your-render-service.onrender.com/api/v1/auth/microsoft/callback

OUTLOOK_NVITE_FOLDER=Nvite
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
REPORT_TZ=Asia/Kolkata

############################
# Frontend (Netlify)
############################
VITE_BASE_URL=https://your-render-service.onrender.com/api/v1
